{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2024", "DOM", "DOM.Iterable"],
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "noUncheckedIndexedAccess": true,
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "@audiocomic/domain": ["./packages/domain/src/index.ts"],
      "@audiocomic/shared": ["./packages/shared/src/index.ts"],
      "@audiocomic/db": ["./packages/db/src/index.ts"],
      "@audiocomic/ai": ["./packages/ai/src/index.ts"],
      "@audiocomic/renderers": ["./packages/renderers/src/index.ts"],
      "@audiocomic/media": ["./packages/media/src/index.ts"],
      "@audiocomic/workflows": ["./packages/workflows/src/index.ts"],
      "@audiocomic/evals": ["./packages/evals/src/index.ts"],
      "@audiocomic/knowledge": ["./packages/knowledge/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist", ".next"]
}
