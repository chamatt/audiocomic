{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
      "@audiocomic/actors": ["../../packages/actors/src/index.ts"],
      "@audiocomic/actors/*": ["../../packages/actors/*"],
      "@audiocomic/shared": ["../../packages/shared/src/index.ts"],
      "@audiocomic/db": ["../../packages/db/src/index.ts"],
      "@audiocomic/workflows": ["../../packages/workflows/src/index.ts"],
      "@audiocomic/domain": ["../../packages/domain/src/index.ts"],
      "@audiocomic/media": ["../../packages/media/src/index.ts"],
      "@audiocomic/storage": ["../../packages/storage/src/index.ts"]
    },
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
