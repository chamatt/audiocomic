# ============================================================================
# AudioComic — Environment Configuration
# Copy this file to .env and fill in the values you need.
# ============================================================================

# --- Database ---
# Postgres connection string (with pgvector extension installed)
DATABASE_URL=postgres://audiocomic:audiocomic@localhost:5432/audiocomic

# --- Object Storage (S3-compatible; leave empty for local filesystem) ---
# STORAGE_ENDPOINT=
# STORAGE_REGION=us-east-1
# STORAGE_BUCKET=audiocomic
# STORAGE_ACCESS_KEY=
# STORAGE_SECRET_KEY=
STORAGE_USE_LOCAL=true

# --- AI Providers (at least one LLM + one image provider recommended) ---

# OpenAI (transcription, LLM, TTS, image generation)
OPENAI_API_KEY=

# Anthropic (LLM only)
# ANTHROPIC_API_KEY=

# Google (LLM only)
# GOOGLE_GENERATIVE_AI_API_KEY=

# Groq (fast LLM + transcription)
# GROQ_API_KEY=

# --- Rendering Backends ---

# ComfyUI (open-model rendering; requires a running ComfyUI server)
# COMFYUI_URL=http://127.0.0.1:8188
# COMFYUI_API_KEY=

# Fal (hosted open-model APIs)
# FAL_KEY=

# --- TTS ---
# ElevenLabs (high-quality TTS)
# ELEVENLABS_API_KEY=

# --- Media ---
# FFmpeg binaries (defaults to system PATH)
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe

# --- App ---
WEB_PORT=3000
WORKER_CONCURRENCY=4
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports

# --- Feature Flags ---
FEATURE_DIARIZATION=true
FEATURE_TTS_FALLBACK=false
FEATURE_PANEL_QA=true
FEATURE_MOTION_COMIC=true

# --- Defaults ---
# Renderer: comfyui | aisdk | placeholder
DEFAULT_RENDERER=placeholder
DEFAULT_LLM_MODEL=gpt-4o
DEFAULT_IMAGE_MODEL=flux-dev
DEFAULT_TTS_VOICE=alloy
