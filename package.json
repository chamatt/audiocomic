{
  "name": "audiocomic",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "db:up": "docker-compose up -d postgres",
    "db:down": "docker-compose down",
    "db:logs": "docker-compose logs -f postgres",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "dev": "bun run --filter web dev",
    "db:generate": "bun run --filter @audiocomic/db generate",
    "db:migrate": "bun run --filter @audiocomic/db migrate",
    "db:push": "bun run --filter @audiocomic/db push",
    "seed": "bun run --filter @audiocomic/workflows seed",
    "cli": "bun run --filter @audiocomic/workflows cli",
    "worker": "bun run --filter @audiocomic/workflows worker",
    "format": "oxfmt --write .",
    "lint": "bun run --filter '*' lint"
  },
  "devDependencies": {
    "@effect/platform-node": "4.0.0-beta.66",
    "@rivetkit/effect": "^2.3.2",
    "@types/bun": "^1.3.14",
    "@types/node": "^22.10.0",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "effect": "4.0.0-beta.66",
    "oxfmt": "^0.56.0",
    "prettier": "^3.4.0",
    "rivetkit": "^2.3.2",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "bun": ">=1.3.0"
  }
}
